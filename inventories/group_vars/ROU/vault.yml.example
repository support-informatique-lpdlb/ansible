---
# ===========================================================================
# Secrets du site ROU.
#
# 1. Copier :   cp vault.yml.example vault.yml
# 2. Renseigner les vraies valeurs
# 3. Chiffrer :  ansible-vault encrypt vault.yml
#
# Seul vault.yml (chiffré) est chargé par Ansible ; ce fichier .example ne l'est
# pas (extension non reconnue), il sert uniquement de modèle.
# ===========================================================================

# --- Compte utilisé par Ansible pour se connecter (SSH) ---
# Switch neuf : admin / switch (défaut usine) ; onboard.yml positionne ensuite
# les mots de passe définitifs ci-dessous.
vault_aos8_user: admin
vault_aos8_password: "CHANGEME"

# --- Comptes locaux positionnés par onboard.yml ---
vault_user_admin_password:    "CHANGEME"
vault_user_adminacs_password: "CHANGEME"

# --- Clé partagée RADIUS / ISE (802.1X) ---
vault_radius_key: "CHANGEME"
